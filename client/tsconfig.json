{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["src/components/*"], 
      "@/lib/*": ["src/lib/*"]
    },
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "moduleResolution": "node", 
    "skipLibCheck": true,
    "target": "es2020",
    "module": "es2020",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  }
}